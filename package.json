  "bugs": {
    "url": "https://github.com/RocketChat/OpenClaw.Plugin/issues"
  },
  "homepage": "https://github.com/RocketChat/OpenClaw.Plugin#readme",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  }
}
